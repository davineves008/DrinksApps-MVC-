@{
    ViewData["Title"] = "DrinksApps";
}

<div class="container py-5">

    <div class="text-center mb-5">
        <h1 class="display-3 fw-bold text-danger">🍔 DrinksApps</h1>
        <p class="lead text-secondary">
            Escolha sua categoria favorita e faça seu pedido.
        </p>
    </div>

    <div class="row justify-content-center g-4">

        <div class="col-md-5">
            <div class="card shadow-lg border-0 h-100">
                <img src="~/img/lanches.jpg" class="card-img-top" height="250" style="object-fit:cover;" />

                <div class="card-body text-center">
                    <h3 class="card-title">🍔 Lanches</h3>

                    <p class="card-text">
                        Hambúrgueres, pizzas, porções e muito mais.
                    </p>

                    <a asp-controller="Produtos"
                       asp-action="Lanches"
                       class="btn btn-danger btn-lg w-100">
                        Ver Lanches
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-5">
            <div class="card shadow-lg border-0 h-100">
                <img src="~/img/bebidas.jpg" class="card-img-top" height="250" style="object-fit:cover;" />

                <div class="card-body text-center">
                    <h3 class="card-title">🥤 Bebidas</h3>

                    <p class="card-text">
                        Refrigerantes, sucos, energéticos e muito mais.
                    </p>

                    <a asp-controller="Produtos"
                       asp-action="Bebidas"
                       class="btn btn-primary btn-lg w-100">
                        Ver Bebidas
                    </a>
                </div>
            </div>
        </div>

    </div>

</div>