@{
    ViewData["Title"] = "DrinksApps";
}

<style>
    body {
        background: #f5f6fa;
    }

    .hero {
        text-align: center;
        margin: 40px 0 60px;
    }

        .hero h1 {
            font-size: 60px;
            font-weight: bold;
            color: #dc3545;
        }

        .hero p {
            color: #666;
            font-size: 22px;
        }

    .categoria-card {
        border: none;
        border-radius: 20px;
        overflow: hidden;
        transition: .35s;
        box-shadow: 0 15px 30px rgba(0,0,0,.12);
        background: white;
    }

        .categoria-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 25px 45px rgba(0,0,0,.2);
        }

        .categoria-card img {
            width: 100%;
            height: 280px;
            object-fit: cover;
            transition: .4s;
        }

        .categoria-card:hover img {
            transform: scale(1.05);
        }

        .categoria-card .card-body {
            padding: 30px;
            text-align: center;
        }

        .categoria-card h3 {
            font-weight: bold;
            margin-bottom: 15px;
        }

        .categoria-card p {
            color: #666;
            margin-bottom: 25px;
        }

    .btn-lanches {
        background: #dc3545;
        color: white;
        border-radius: 10px;
        font-size: 18px;
        font-weight: bold;
    }

        .btn-lanches:hover {
            background: #bb2d3b;
            color: white;
        }

    .btn-bebidas {
        background: #0d6efd;
        color: white;
        border-radius: 10px;
        font-size: 18px;
        font-weight: bold;
    }

        .btn-bebidas:hover {
            background: #0b5ed7;
            color: white;
        }

    .info-box {
        background: white;
        border-radius: 15px;
        padding: 30px;
        box-shadow: 0 10px 25px rgba(0,0,0,.08);
        margin-top: 70px;
    }

        .info-box h4 {
            font-weight: bold;
            margin-bottom: 20px;
        }

    .info-item {
        font-size: 18px;
        margin-bottom: 10px;
    }

    footer {
        margin-top: 80px;
        padding: 25px;
        text-align: center;
        color: #777;
    }
</style>

<div class="container">

    <div class="hero">

        <h1>🍔 DrinksApps</h1>

        <p>
            Escolha sua categoria favorita e faça seu pedido.
        </p>

    </div>

    <div class="row g-4">

        <!-- Lanches -->

        <div class="col-lg-6">

            <div class="categoria-card">

                <img src="~/images/produtos/lanches.jpg" asp-append-version="true">

                <div class="card-body">

                    <h3>🍔 Lanches</h3>

                    <p>
                        Hambúrgueres artesanais, pizzas, batatas,
                        porções e muito mais.
                    </p>

                    <div class="d-grid">
                        <a asp-controller="Produtos"
                           asp-action="Lanches"
                           class="btn btn-lg btn-lanches">
                            Ver Lanches
                        </a>

                    </div>

                </div>

            </div>

        </div>

        <!-- Bebidas -->

        <div class="col-lg-6">

            <div class="categoria-card">

                <img src="~/images/produtos/bebidas.jpg" asp-append-version="true">

                <div class="card-body">

                    <h3>🥤 Bebidas</h3>

                    <p>
                        Refrigerantes, sucos, energéticos,
                        águas e muito mais.
                    </p>

                    <div class="d-grid">

                        <a asp-controller="Produtos"
                           asp-action="Bebidas"
                           class="btn btn-lg btn-bebidas">
                            Ver Bebidas
                        </a>

                    </div>

                </div>

            </div>

        </div>

    </div>

    <!-- Informações -->

    <div class="info-box">

        <div class="row text-center">

            <div class="col-md-4">

                <div class="info-item">
                    🚀 <strong>Entrega Rápida</strong>
                </div>

                <small>Receba seu pedido em poucos minutos.</small>

            </div>

            <div class="col-md-4">

                <div class="info-item">
                    🍔 <strong>Produtos Frescos</strong>
                </div>

                <small>Ingredientes selecionados todos os dias.</small>

            </div>

            <div class="col-md-4">

                <div class="info-item">
                    ⭐ <strong>Qualidade Garantida</strong>
                </div>

                <small>Satisfação garantida em cada pedido.</small>

            </div>

        </div>

    </div>

    <footer>

        <hr>

        <h5>🍔 DrinksApps</h5>

        <p>
            Seu delivery favorito de lanches e bebidas.
        </p>

        <small>
            © @DateTime.Now.Year DrinksApps - Todos os direitos reservados.
        </small>

    </footer>

</div>