@model DrinksApps.Models.Produto

@{
    ViewData["Title"] = "Novo Produto";
}

<style>
    body {
        background: linear-gradient(135deg, #fff8f0, #ffe8cc);
    }

    .card-produto {
        border: none;
        border-radius: 22px;
        overflow: hidden;
    }

    .card-header {
        background: linear-gradient(135deg, #ff6b00, #ff9800);
        color: white;
        border: none;
    }

    .card-body {
        background: white;
    }

    .form-control,
    .form-select {
        border-radius: 12px;
        padding: 12px;
        border: 1px solid #ddd;
        transition: .3s;
    }

        .form-control:focus,
        .form-select:focus {
            border-color: #ff7a00;
            box-shadow: 0 0 10px rgba(255,122,0,.25);
        }

    .btn-salvar {
        background: linear-gradient(135deg,#ff6b00,#ff9800);
        color: white;
        border: none;
        border-radius: 12px;
        padding: 12px 30px;
        font-weight: bold;
        transition: .3s;
    }

        .btn-salvar:hover {
            transform: translateY(-2px);
            color: white;
            box-shadow: 0 10px 20px rgba(255,122,0,.35);
        }

    .btn-outline-secondary {
        border-radius: 12px;
        padding: 12px 30px;
    }

    .form-check-input {
        transform: scale(1.2);
    }

        .form-check-input:checked {
            background-color: #ff7a00;
            border-color: #ff7a00;
        }

    hr {
        opacity: .15;
    }
</style>

<div class="container py-5">

    <div class="row justify-content-center">

        <div class="col-lg-8">

            <div class="card card-produto shadow-lg">

                <div class="card-header text-center py-3">
                    <h2 class="mb-0">
                        <i class="bi bi-plus-circle-fill"></i>
                        Cadastro de Produto
                    </h2>
                </div>

                <div class="card-body p-4">

                    <form asp-action="Create" enctype="multipart/form-data">

                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <div class="row">

                            <div class="col-md-6 mb-3">
                                <label asp-for="Nome" class="form-label fw-bold"></label>
                                <input asp-for="Nome" class="form-control" />
                                <span asp-validation-for="Nome" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Preco" class="form-label fw-bold"></label>

                                <input name="preco"
                                       class="form-control"
                                       type="text"
                                       placeholder="Ex: 10,50" />

                                <span asp-validation-for="Preco" class="text-danger"></span>
                            </div>

                            <div class="col-md-12 mb-3">
                                <label asp-for="Descricao" class="form-label fw-bold"></label>
                                <textarea asp-for="Descricao" rows="3" class="form-control"></textarea>
                                <span asp-validation-for="Descricao" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Estoque" class="form-label fw-bold"></label>
                                <input asp-for="Estoque" class="form-control" />
                                <span asp-validation-for="Estoque" class="text-danger"></span>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label">Imagem do Produto</label>

                                <input type="file"
                                       name="imagem"
                                       class="form-control"
                                       accept="image/*" />
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Categoria</label>

                                <select asp-for="CategoriaId"
                                        class="form-select"
                                        asp-items="ViewBag.Categorias">
                                </select>

                                <span asp-validation-for="CategoriaId" class="text-danger"></span>
                            </div>

                            <div class="form-check form-switch mt-4">

                                <input asp-for="Ativo"
                                       class="form-check-input" />

                                <label asp-for="Ativo"
                                       class="form-check-label fw-bold">
                                    Produto Disponível
                                </label>

                            </div>

                        </div>

                        <hr />

                        <div class="d-flex justify-content-between">

                            <a href="javascript:history.back()"
                               class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left"></i>
                                Voltar
                            </a>

                            <button type="submit" class="btn btn-salvar">
                                <i class="bi bi-floppy-fill"></i>
                                Salvar Produto
                            </button>

                        </div>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    
}
