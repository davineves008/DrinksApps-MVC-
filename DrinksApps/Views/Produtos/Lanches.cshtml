@model IEnumerable<DrinksApps.Models.Produto>
@{
    var perfil = Context.Session.GetString("Perfil") ?? "";
}
<style>
    .page-card {
        background: #fff;
        border-radius: 16px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.08);
        overflow: hidden;
    }

    .page-header {
        padding: 20px 25px;
        background: linear-gradient(135deg, #fd7e14, #ffb703);
        color: #fff;
    }

        .page-header h2 {
            margin: 0;
            font-weight: 600;
        }

    .page-body {
        padding: 20px;
    }

    .table-hover tbody tr:hover {
        background-color: #fff6ed;
        transition: 0.2s;
    }

    .table thead {
        background: #f8f9fa;
    }

    .btn-new {
        background: #fff;
        color: #fd7e14;
        font-weight: 600;
        border-radius: 10px;
        padding: 8px 14px;
        transition: 0.2s;
        text-decoration: none;
    }

        .btn-new:hover {
            background: #ffe8cc;
            transform: scale(1.03);
        }

    .price {
        font-weight: 600;
        color: #198754;
    }

    .badge-estoque {
        padding: 6px 10px;
        border-radius: 12px;
        font-size: 12px;
    }

    .estoque-ok {
        background: #d1e7dd;
        color: #0f5132;
    }

    .estoque-baixo {
        background: #fff3cd;
        color: #664d03;

    }

    .card:hover {
        transform: translateY(-5px);
        transition: 0.2s;
    }
</style>

<div class="container py-5">

    <div class="page-card">

        <div class="page-header d-flex justify-content-between align-items-center">
            <h2>🍔 Lanches</h2>
          
            @if (perfil == "Administrador")
            {
                <a asp-action="Create" class="btn btn-new">
                    + Novo Lanche
                </a>
            }
        </div>

        <div class="row g-4">

            @foreach (var item in Model)
            {
                <div class="col-md-4 col-sm-6">

                    <div class="card h-100 shadow-sm border-0">
                        <div class="card-img-top bg-light text-center py-4">
                            <img src="@item.ImagemUrl" class="img-fluid" style="max-height:200px;" />
                        </div>


                        <div class="card-body">
                            <h5 class="card-title fw-bold">
                                @item.Nome
                            </h5>

                            <p class="mb-2">
                                <span class="price">
                                    @item.Preco.ToString("C")
                                </span>
                            </p>

                            <p class="mb-2">
                                Estoque:
                                @if (item.Estoque <= 5)
                                {
                                    <span class="badge-estoque estoque-baixo">
                                        @item.Estoque
                                    </span>
                                }
                                else
                                {
                                    <span class="badge-estoque estoque-ok">
                                        @item.Estoque
                                    </span>
                                }
                            </p>
                        </div>

                        <div class="card-footer bg-white border-0 d-flex justify-content-between">

                            <a asp-action="Details" asp-route-id="@item.Id"
                               class="btn btn-outline-primary btn-sm">
                                Visualizar
                            </a>

                            @if (perfil == "Administrador")
                            {
                                <div>
                                    <a asp-action="Edit" asp-route-id="@item.Id"
                                       class="btn btn-warning btn-sm">
                                        Editar
                                    </a>

                                    <a asp-action="Delete" asp-route-id="@item.Id"
                                       class="btn btn-danger btn-sm">
                                        Excluir
                                    </a>
                                </div>
                            }

                        </div>

                    </div>

                </div>
            }

        </div>

    </div>

</div>