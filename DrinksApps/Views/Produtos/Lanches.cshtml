@model IEnumerable<DrinksApps.Models.Produto>
@{
    var perfil = Context.Session.GetString("Perfil") ?? "";
}
<style>
    .page-card {
        background: #fff;
        border-radius: 16px;
        box-shadow: 0 10px 25px rgba(0,0,0,.08);
        overflow: hidden;
        border: 1px solid #ffe2c4;
    }

    .page-header {
        padding: 20px 25px;
        background: linear-gradient(135deg,#ff7a00,#ff9900);
        color: white;
    }

        .page-header h2 {
            margin: 0;
            font-weight: 700;
        }

    .page-body {
        padding: 20px;
    }

    .table thead {
        background: #fff4e6;
        color: #ff7a00;
        font-weight: 600;
    }

    .table-hover tbody tr:hover {
        background: #fff8f1;
        transition: .2s;
    }

    .btn-new {
        background: linear-gradient(135deg,#ff7a00,#ff9900);
        color: white;
        border: none;
        border-radius: 10px;
        padding: 8px 16px;
        font-weight: 600;
        text-decoration: none;
        transition: .3s;
    }

        .btn-new:hover {
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(255,122,0,.35);
        }

    .price {
        font-weight: bold;
        color: #ff7a00;
        font-size: 17px;
    }

    .badge-estoque {
        padding: 6px 12px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
    }

    .estoque-ok {
        background: #e8f8ee;
        color: #198754;
    }

    .estoque-baixo {
        background: #fff4e6;
        color: #ff7a00;
    }

    .card {
        border: none;
        border-radius: 16px;
        box-shadow: 0 6px 18px rgba(0,0,0,.08);
        transition: .3s;
    }

        .card:hover {
            transform: translateY(-5px);
            box-shadow: 0 12px 28px rgba(255,122,0,.20);
        }

    .btn-success {
        background: linear-gradient(135deg, #ff7a00, #ff9900);
        border: none;
        color: white;
    }

        .btn-success:hover {
            background: linear-gradient(135deg, #e86f00, #ff7a00);
            color: white;
        }

    .btn-warning {
        background: #ff9900;
        border: none;
        color: white;
    }

        .btn-warning:hover {
            background: #e86f00;
            color: white;
        }

    .btn-danger {
        background: #dc3545;
        border: none;
    }

        .btn-danger:hover {
            background: #bb2d3b;
        }


</style>

@if (TempData["Sucesso"] != null)
{
    <div class="alert alert-success">
        @TempData["Sucesso"]
    </div>
}

<div class="container py-5">

    <div class="page-card">

        <div class="page-header d-flex justify-content-between align-items-center">
            <h2>🍔 Lanches</h2>

            @if (perfil == "Administrador")
            {
                <a asp-action="Create" class="btn btn-new">
                    + Novo Lanche
                </a>
            }
        </div>

        <div class="row g-4">

            @foreach (var item in Model)
            {
                <div class="col-md-4 col-sm-6">

                    <div class="card h-100 shadow-sm border-0">
                        <div class="card-img-top bg-light text-center py-4  ">
                            <img src="@item.ImagemUrl" class="img-fluid" style="max-height:200px;   border-radius: 15px;" />
                        </div>


                        <div class="card-body">
                            <h5 class="card-title fw-bold">
                                @item.Nome
                            </h5>

                            <p class="mb-2">
                                <span class="price">
                                    @item.Preco.ToString("C")
                                </span>
                            </p>

                            <p class="mb-2">
                                Estoque:
                                @if (item.Estoque <= 5)
                                {
                                    <span class="badge-estoque estoque-baixo">
                                        @item.Estoque
                                    </span>
                                }
                                else
                                {
                                    <span class="badge-estoque estoque-ok">
                                        @item.Estoque
                                    </span>
                                }
                            </p>
                            <div class="mb-2">
                                @if (item.Ativo)
                                {
                                    <span class="badge bg-success px-3 py-2">🟢 Disponível</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary px-3 py-2">🔴 Indisponível</span>
                                }
                            </div>

                        </div>

                        <div class="card-footer bg-white border-0 d-flex justify-content-between">
                            @if (item.Ativo)
                            {
                                <a asp-controller="Carrinho"
                                   asp-action="Adicionar"
                                   asp-route-id="@item.Id"
                                   class="btn btn-success btn-sm">

                                    🛒 Adicionar
                                </a>
                            }
                            else
                            {
                                <button class="btn btn-secondary btn-sm" disabled>
                                    Indisponível
                                </button>
                            }

                            @if (perfil == "Administrador")
                            {
                                <div>


                                    <a asp-action="Edit" asp-route-id="@item.Id"
                                       class="btn btn-warning btn-sm">
                                        Editar
                                    </a>

                                    <a asp-action="Delete" asp-route-id="@item.Id"
                                       class="btn btn-danger btn-sm">
                                        Excluir
                                    </a>
                                </div>
                            }

                        </div>

                    </div>

                </div>
            }

        </div>

    </div>

</div>