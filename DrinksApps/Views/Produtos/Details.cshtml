@model DrinksApps.Models.Produto

@{
    ViewData["Title"] = "Detalhes do Produto";
}

<div class="container mt-4">

    <div class="row justify-content-center">

        <div class="col-lg-8">

            <div class="card shadow-lg border-0 rounded-4">

                <div class="card-header bg-primary text-white text-center py-3">
                    <h3 class="mb-0">
                        📦 Detalhes do Produto
                    </h3>
                </div>

                <div class="card-body p-4">

                    <div class="row">

                        <!-- Imagem -->

                        <div class="col-md-5 text-center">

                            @if (!string.IsNullOrEmpty(Model.ImagemUrl))
                            {
                                <img src="@Model.ImagemUrl"
                                     class="img-fluid rounded shadow"
                                     style="max-height:300px;" />
                            }
                            else
                            {
                                <img src="~/images/sem-imagem.png"
                                     class="img-fluid rounded shadow"
                                     style="max-height:300px;" />
                            }

                        </div>

                        <!-- Informações -->

                        <div class="col-md-7">

                            <h2 class="fw-bold text-primary">
                                @Model.Nome
                            </h2>

                            <hr />

                            <p>
                                <strong>📝 Descrição:</strong><br />
                                @Model.Descricao
                            </p>

                            <p>
                                <strong>💰 Preço:</strong><br />
                                <span class="fs-4 text-success fw-bold">
                                    @Model.Preco.ToString("C")
                                </span>
                            </p>

                            <p>
                                <strong>📦 Estoque:</strong><br />

                                @if (Model.Estoque > 0)
                                {
                                    <span class="badge bg-success fs-6">
                                        @Model.Estoque unidades
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-danger fs-6">
                                        Esgotado
                                    </span>
                                }
                            </p>

                            <p>
                                <strong>📂 Categoria:</strong><br />

                                @if (Model.Categoria != null)
                                {
                                    @Model.Categoria.Nome
                                }
                                else
                                {
                                    <span class="text-muted">Não informada</span>
                                }

                            </p>

                            <p>
                                <strong>Status:</strong><br />

                                @if (Model.Ativo)
                                {
                                    <span class="badge bg-success fs-6">
                                        🟢 Disponível
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-danger fs-6">
                                        🔴 Indisponível
                                    </span>
                                }

                            </p>

                        </div>

                    </div>

                </div>

                <div class="card-footer bg-white">

                    <div class="d-flex justify-content-between">


                        <a href="javascript:history.back()" class="btn btn-outline-secondary">
                            ← Voltar
                        </a>

                        <a asp-action="Edit"
                           asp-route-id="@Model.Id"
                           class="btn btn-warning">

                            ✏ Editar Produto

                        </a>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}