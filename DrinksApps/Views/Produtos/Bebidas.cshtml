@model IEnumerable<DrinksApps.Models.Produto>
@{
    var perfil = Context.Session.GetString("Perfil") ?? "";
}
<style>
    .page-card {
        background: #fff;
        border-radius: 16px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.08);
        overflow: hidden;
    }

    .page-header {
        padding: 20px 25px;
        background: linear-gradient(135deg, #0d6efd, #4dabf7);
        color: #fff;
    }

        .page-header h2 {
            margin: 0;
            font-weight: 600;
        }

    .page-body {
        padding: 20px;
    }

    .table-hover tbody tr:hover {
        background-color: #f1f7ff;
        transition: 0.2s;
    }

    .table thead {
        background: #f8f9fa;
    }

    .btn-new {
        background: #fff;
        color: #0d6efd;
        font-weight: 600;
        border-radius: 10px;
        padding: 8px 14px;
        transition: 0.2s;
    }

        .btn-new:hover {
            background: #e9f2ff;
            transform: scale(1.03);
        }

    .price {
        font-weight: 600;
        color: #198754;
    }

    .badge-estoque {
        padding: 6px 10px;
        border-radius: 12px;
        font-size: 12px;
    }

    .estoque-ok {
        background: #d1e7dd;
        color: #0f5132;
    }

    .estoque-baixo {
        background: #fff3cd;
        color: #664d03;
    }
</style>

<div class="container py-5">

    <div class="page-card">

        <div class="page-header d-flex justify-content-between align-items-center">
            <h2>🥤 Bebidas</h2>
            @if (perfil == "Administrador")
            {
                <a asp-controller="Produtos"
                   asp-action="Create"
                   asp-route-categoriaId="2"
                   class="btn btn-new">
                    + Nova Bebida
                </a>
            }
        </div>

        <div class="page-body">

            <table class="table table-hover align-middle">
                <thead>
                    <tr>
                        <th>Nome</th>
                        <th>Preço</th>
                        <th>Estoque</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Nome</td>

                            <td class="price">
                                @item.Preco.ToString("C")
                            </td>

                            <td>
                                @if (item.Estoque <= 5)
                                {
                                    <span class="badge-estoque estoque-baixo">
                                        @item.Estoque
                                    </span>
                                }
                                else
                                {
                                    <span class="badge-estoque estoque-ok">
                                        @item.Estoque
                                    </span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>

            </table>

        </div>

    </div>

</div>