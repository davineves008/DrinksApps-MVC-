@model IEnumerable<DrinksApps.Models.Produto>

@{
    ViewData["Title"] = "Produtos";
}
@{
    var perfil = Context.Session.GetString("Perfil");
}

<style>
    body {
        background: linear-gradient(135deg,#fff8f0,#ffe8cc);
    }

    .page-header {
        background: linear-gradient(135deg,#ff6b00,#ff9800);
        color: white;
        padding: 22px 28px;
        border-radius: 18px;
        margin-bottom: 30px;
        box-shadow: 0 10px 25px rgba(255,122,0,.25);
    }

    .btn-new {
        background: white;
        color: #ff6b00;
        border-radius: 12px;
        padding: 10px 18px;
        font-weight: bold;
        transition: .3s;
    }

        .btn-new:hover {
            background: #fff3e6;
            color: #ff6b00;
            transform: translateY(-2px);
        }

    .produto-card {
        border: none;
        border-radius: 22px;
        overflow: hidden;
        box-shadow: 0 12px 25px rgba(0,0,0,.08);
        transition: .35s;
        background: white;
    }

        .produto-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 18px 35px rgba(0,0,0,.15);
        }

    .produto-img {
        width: 100%;
        height: 220px;
        object-fit: cover;
    }

    .produto-body {
        padding: 15px;
    }

    .produto-nome {
        font-size: 22px;
        font-weight: bold;
        color: #ff6b00;
    }

    .produto-desc {
        color: #666;
        font-size: 14px;
        min-height: 45px;
    }

    .produto-info {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 10px;
    }

    .price {
        font-size: 24px;
        font-weight: bold;
        color: #198754;
    }

    .badge-status {
        padding: 8px 14px;
        border-radius: 30px;
        font-size: 12px;
        font-weight: bold;
    }

    .ativo {
        background: #d1e7dd;
        color: #0f5132;
    }

    .inativo {
        background: #f8d7da;
        color: #842029;
    }

    .actions {
        margin-top: 10px;
        display: flex;
        gap: 5px;
    }

        .actions a {
            flex: 1;
            text-align: center;
            font-size: 13px;
            border-radius: 8px;
        }
</style>

<div class="container py-5">

    <div class="page-header d-flex justify-content-between align-items-center">
        <h2>🍔 Produtos</h2>
        @if (perfil == "Administrador")
        {
            <a asp-action="Create" class="btn btn-new">
                ➕ Novo Produto
            </a>
        }
    </div>

    <div class="row g-4">

        @foreach (var item in Model)
        {
            <div class="col-md-4 col-lg-3">

                <div class="card produto-card">

                    @if (!string.IsNullOrEmpty(item.ImagemUrl))
                    {
                        <img src="@item.ImagemUrl" class="produto-img" />
                    }
                    else
                    {
                        <div class="produto-img d-flex align-items-center justify-content-center text-muted">
                            Sem imagem
                        </div>
                    }

                    <div class="produto-body">

                        <div class="produto-nome">
                            @item.Nome
                        </div>

                        <div class="produto-desc">
                            @item.Descricao
                        </div>

                        <div class="produto-info">
                            <span class="price">
                                @item.Preco.ToString("C")
                            </span>

                            @if (item.Ativo)
                            {
                                <span class="badge-status ativo">Ativo</span>
                            }
                            else
                            {
                                <span class="badge-status inativo">Inativo</span>
                            }
                        </div>

                        <div class="mt-2">

                            <span class="badge bg-secondary">
                                📦 @item.Estoque
                            </span>

                            <span class="badge bg-warning text-dark">
                                📂 @item.Categoria?.Nome
                            </span>

                        </div>

                        <div class="actions mt-3">

                            @if (perfil == "Administrador")
                            {
                                <a asp-action="Edit"
                                   asp-route-id="@item.Id"
                                   class="btn btn-warning">
                                    <i class="bi bi-pencil-fill"></i>
                                </a>

                                <a asp-action="Delete"
                                   asp-route-id="@item.Id"
                                   class="btn btn-danger">
                                    <i class="bi bi-trash-fill"></i>
                                </a>
                            }

                            <a asp-action="Details"
                               asp-route-id="@item.Id"
                               class="btn btn-primary">
                                <i class="bi bi-eye-fill"></i>
                            </a>

                        </div>
                    </div>

                </div>

            </div>
        }

    </div>

</div>