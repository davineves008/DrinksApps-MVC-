@model DrinksApps.Models.Produto

@{
    ViewData["Title"] = "Excluir Produto";
}

<style>
    body {
        background: linear-gradient(135deg, #fff8f0, #ffe8cc);
    }

    .card-delete {
        border: none;
        border-radius: 22px;
        overflow: hidden;
    }

    .card-header {
        background: linear-gradient(135deg, #ff6b00, #ff9800);
        color: #fff;
        border: none;}

    .produto-img {
        width: 100%;
        max-height: 320px;
        object-fit: cover;
        border-radius: 18px;
        box-shadow: 0 12px 25px rgba(0,0,0,.18);
    }

    .info-box {
        background: #fffaf5;
        border-radius: 15px;
        padding: 18px;
        margin-bottom: 15px;
        border-left: 5px solid #ff7a00;
    }

    .btn-danger {
        background: linear-gradient(135deg, #dc3545, #ff5c70);
        border: none;
        border-radius: 12px;
        padding: 12px 28px;
        font-weight: bold;
        transition: .3s;
    }

        .btn-danger:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(220,53,69,.35);
        }
    .btn-outline-secondary {
        border-radius: 12px;
        padding: 12px 28px;
        transition: .3s;
    }

        .btn-outline-secondary:hover {
            background: #6c757d;
            color: white;
        }

    .alert-warning {
        border: none;
        border-radius: 15px;
        background: #fff3cd;
        color: #7a4e00;
    }

    .badge {
        font-size: .9rem;
        padding: 8px 14px;
    }

    .titulo-produto {
        font-weight: bold;
        color: #ff7a00;
        margin-bottom: 20px;
    }

    .card-footer {
        background: white;
        border: none;
        padding: 25px;
    }

    hr {
        opacity: .15;
    }
</style>

<div class="container mt-4">

    <div class="row justify-content-center">

        <div class="col-lg-8">

            <div class="card card-delete shadow-lg">

                <div class="card-header bg-danger text-white text-center py-3">
                    <h3 class="mb-0">
                        🗑 Excluir Produto
                    </h3>
                </div>

                <div class="card-body p-4">

                    <div class="alert alert-warning text-center">

                        <h5 class="mb-0">
                            ⚠ Tem certeza que deseja excluir este produto?
                        </h5>

                        <small>
                            Esta ação não poderá ser desfeita.
                        </small>

                    </div>

                    <div class="row">

                        <!-- Imagem -->

                        <div class="col-md-5 text-center mt-5">

                            @if (!string.IsNullOrEmpty(Model.ImagemUrl))
                            {
                                <img src="@Model.ImagemUrl"
                                     class="produto-img"
                                     style="max-height:280px;"
                                     />
                            }
                            else
                            {
                                <img src="~/images/sem-imagem.png"
                                     class="produto-img"
                                     style="max-height:280px;" />
                            }

                        </div>
                        <!-- Informações -->

                        <div class="col-md-7">

                            <h2 class="titulo-produto">
                                🍔 @Model.Nome
                            </h2>

                            <div class="info-box">

                                <p>
                                    <strong>📝 Descrição</strong><br />
                                    @Model.Descricao
                                </p>

                                <hr>

                                <p>
                                    <strong>💰 Preço</strong><br />
                                    <span class="fs-3 fw-bold text-success">
                                        @Model.Preco.ToString("C")
                                    </span>
                                </p>

                                <hr>

                                <p>
                                    <strong>📦 Estoque</strong><br />

                                    @if (Model.Estoque > 0)
                                    {
                                        <span class="badge bg-success">
                                            @Model.Estoque unidades
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">
                                            Esgotado
                                        </span>
                                    }

                                </p>

                                <hr>

                                <p>
                                    <strong>📂 Categoria</strong><br />
                                    @(Model.Categoria?.Nome ?? "Não informada")
                                </p>

                                <hr>

                                <p>
                                    <strong>Status</strong><br />

                                    @if (Model.Ativo)
                                    {
                                        <span class="badge bg-success">
                                            ✔ Disponível
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">
                                            ✖ Indisponível
                                        </span>
                                    }

                                </p>

                            </div>
                            </div>

                    </div>

                </div>

                <div class="card-footer bg-white">

                    <form asp-action="Delete" method="post">

                        <input type="hidden" asp-for="Id" />

                        <div class="d-flex justify-content-between">

                            <a href="javascript:history.back()"
                               class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left"></i>
                                Cancelar
                            </a>

                            <button type="submit"
                                    class="btn btn-danger">
                                <i class="bi bi-trash3-fill"></i>
                                Confirmar Exclusão
                            </button>

                        </div>
                    </form>

                </div>

            </div>

        </div>

    </div>

</div>