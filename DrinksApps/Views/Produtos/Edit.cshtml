@model DrinksApps.Models.Produto

@{
    ViewData["Title"] = "Editar Produto";
}
<style>
    body {
        background: linear-gradient(135deg, #fff8f0, #ffe8cc);
    }

    .card {
        border-radius: 20px;
        overflow: hidden;
    }

    .card-header {
        background: linear-gradient(135deg,#ff6b00,#ff9800);
        color: white;
        border: none;
    }

    .form-control,
    .form-select {
        border-radius: 12px;
        padding: 10px;
        transition: .3s;
    }

        .form-control:focus,
        .form-select:focus {
            border-color: #ff7a00;
            box-shadow: 0 0 10px rgba(255,122,0,.25);
        }

    .btn-salvar {
        background: linear-gradient(135deg,#ff6b00,#ff9800);
        color: white;
        border: none;
        border-radius: 12px;
        font-weight: bold;
        transition: .3s;
    }

        .btn-salvar:hover {
            transform: translateY(-2px);
            color: white;
            box-shadow: 0 8px 20px rgba(255,122,0,.35);
        }

    .btn-voltar {
        border-radius: 12px;
        padding: 10px 20px;
    }

    .img-produto {
        max-height: 220px;
        border-radius: 15px;
        box-shadow: 0 10px 25px rgba(0,0,0,.15);
    }

    .form-check-input:checked {
        background-color: #ff7a00;
        border-color: #ff7a00;
    }

    .card-body {
        background: white;
    }

    h3 {
        font-weight: bold;
    }
</style>



<div class="container mt-4">

    <div class="row justify-content-center">

        <div class="col-lg-8">

            <div class="card shadow-lg border-0 rounded-4">

                <div class="card-header text-center py-3">
                    <h3 class="mb-0">
                        <i class="bi bi-pencil-square"></i> Editar Produto
                    </h3>
                </div>

                <div class="card-body p-4">

                    <form asp-action="Edit" enctype="multipart/form-data">

                        <input type="hidden" asp-for="Id" />

                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <div class="row">

                            <div class="col-md-6">

                                <div class="mb-3">
                                    <label asp-for="Nome" class="form-label fw-bold"></label>
                                    <input asp-for="Nome" class="form-control" />
                                    <span asp-validation-for="Nome" class="text-danger"></span>
                                </div>

                            </div>

                            <div class="col-md-6">

                                <div class="mb-3">
                                    <label asp-for="Preco" class="form-label fw-bold"></label>
                                    <input name="preco"
                                           class="form-control"
                                           type="text"
                                           placeholder="Ex: 10,50" />
                                    <span asp-validation-for="Preco" class="text-danger"></span>
                                </div>

                            </div>

                        </div>

                        <div class="mb-3">
                            <label asp-for="Descricao" class="form-label fw-bold"></label>
                            <textarea asp-for="Descricao"
                                      rows="4"
                                      class="form-control"></textarea>

                            <span asp-validation-for="Descricao" class="text-danger"></span>
                        </div>

                        <div class="row">

                            <div class="col-md-6">

                                <div class="mb-3">
                                    <label asp-for="Estoque" class="form-label fw-bold"></label>
                                    <input asp-for="Estoque" class="form-control" />
                                    <span asp-validation-for="Estoque" class="text-danger"></span>
                                </div>

                            </div>

                            <div class="mb-3">
                                <label asp-for="CategoriaId" class="form-label fw-bold">
                                    Categoria
                                </label>

                                <select asp-for="CategoriaId"
                                        asp-items="ViewBag.Categorias"
                                        class="form-select">

                                    <option value="">Selecione uma categoria</option>

                                </select>

                                <span asp-validation-for="CategoriaId" class="text-danger"></span>
                            </div>

                        </div>

                        @if (!string.IsNullOrEmpty(Model.ImagemUrl))
                        {
                            <div class="text-center mb-3">

                                <label class="fw-bold d-block mb-2">
                                    Imagem Atual
                                </label>

                                <img src="@Model.ImagemUrl"
                                     class="img-produto img-fluid"
                                     style="max-height:220px;" />

                            </div>
                        }

                        <div class="mb-4">

                            <label class="form-label fw-bold">
                                Alterar Imagem
                            </label>

                            <input type="file"
                                   name="imagem"
                                   class="form-control" />

                        </div>

                        <div class="form-check form-switch mb-4">

                            <input asp-for="Ativo"
                                   class="form-check-input"
                                   style="transform:scale(1.3);" />

                            <label asp-for="Ativo"
                                   class="form-check-label fw-bold">
                                Produto Disponível
                            </label>

                        </div>

                        <div class="d-flex justify-content-between">

                            <a href="javascript:history.back()"
                               class="btn btn-outline-secondary btn-voltar">
                                <i class="bi bi-arrow-left"></i> Voltar
                            </a>

                            <button type="submit"
                                    class="btn btn-salvar px-5">
                                <i class="bi bi-check-circle"></i> Salvar Alterações
                            </button>

                        </div>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}