@model DrinksApps.Models.Usuario

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DrinksApps - Cadastro</title>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

    <style>
        /* SEU CSS MANTIDO */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI';
        }

        body {
            background: linear-gradient(135deg,#ff8c00,#ff6b00,#ff9f43);
            background-size: 300% 300%;
            animation: fundo 10s ease infinite;
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .cadastro-container {
            background: rgba(255,255,255,.97);
            width: 100%;
            max-width: 470px;
            padding: 40px;
            border-radius: 25px;
            box-shadow: 0 20px 50px rgba(0,0,0,.25);
            border-top: 6px solid #ff7a00;
            animation: aparecer .6s ease;
        }

        @@keyframes fundo {
            0% {
                background-position: 0% 50%;
            }

            50% {
                background-position: 100% 50%;
            }

            100% {
                background-position: 0% 50%;
            }
        }

        .cadastro-header {
            text-align: center;
            margin-bottom: 30px;
        }

        .logo-icon {
            width: 90px;
            height: 90px;
            margin: auto;
            margin-bottom: 15px;
            border-radius: 50%;
            background: linear-gradient(135deg,#ff6b00,#ff9800);
            display: flex;
            justify-content: center;
            align-items: center;
            font-size: 42px;
            box-shadow: 0 12px 30px rgba(255,122,0,.35);
        }

        .cadastro-header h2 {
            margin: 0;
            color: #ff6b00;
            font-size: 32px;
            font-weight: bold;
        }

        .cadastro-header p {
            color: #777;
            margin-top: 8px;
        }
        .input-group {
            margin-bottom: 1rem;
        }

        label {
            color: #444;
            font-weight: 600;
        }

        .input-wrapper {
            position: relative;
        }

            .input-wrapper i {
                color: #ff7a00;
            }

            .input-wrapper input,
            .input-wrapper select {
                width: 100%;
                height: 48px;
                padding: 0 15px 0 42px;
                border: 1px solid #ddd;
                border-radius: 12px;
                background: #fafafa;
                transition: .3s;
            }

                .input-wrapper input:focus,
                .input-wrapper select:focus {
                    border-color: #ff7a00;
                    background: white;
                    outline: none;
                    box-shadow: 0 0 0 4px rgba(255,122,0,.15);
                }

        .text-danger {
            font-size: 12px;
            color: #dc3545;
            margin-top: 4px;
        }

        .validation-summary-errors {
            color: #dc3545;
            font-size: 13px;
            margin-bottom: 10px;
        }

        .btn-cadastro {
            width: 100%;
            padding: 15px;
            border: none;
            border-radius: 12px;
            background: linear-gradient(135deg,#ff6b00,#ff9800);
            color: white;
            font-size: 17px;
            font-weight: bold;
            transition: .3s;
        }

            .btn-cadastro:hover {
                transform: translateY(-2px);
                box-shadow: 0 10px 25px rgba(255,122,0,.35);
            }

        .btn-voltar {
            width: 100%;
            padding: 15px;
            margin-top: 15px;
            border-radius: 12px;
            border: 2px solid #ff7a00;
            background: white;
            color: #ff7a00;
            font-weight: bold;
            text-decoration: none;
            display: block;
            text-align: center;
            transition: .3s;
        }

            .btn-voltar:hover {
                background: #ff7a00;
                color: white;
            }
            
        @@keyframes aparecer {

            from {
                opacity: 0;
                transform: translateY(35px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }



    </style>
</head>

<body>

    <div class="cadastro-container">

        <div class="cadastro-header">
            <div class="logo-area">

                <div class="logo-icon">
                    🍔🥤
                </div>

                <div class="logo-text">
                    <h1>DrinksApps</h1>
                   
                </div>

            </div>

            <h2>Criar Conta</h2>

            <p>Cadastre-se para começar a utilizar o DrinksApps.</p>

        </div>

        <form asp-action="Index" method="post">
            @Html.AntiForgeryToken()

            <!-- RESUMO DE ERROS -->
            <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

            <!-- NOME -->
            <div class="input-group">
                <label>Nome</label>
                <div class="input-wrapper">
                    <i class="fa fa-user"></i>
                    <input asp-for="Nome" />
                </div>
                <span asp-validation-for="Nome" class="text-danger"></span>
            </div>

            <!-- EMAIL -->
            <div class="input-group">
                <label>Email</label>
                <div class="input-wrapper">
                    <i class="fa fa-envelope"></i>
                    <input asp-for="Email" placeholder="Digite seu e-mail" />
                </div>
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <!-- TELEFONE -->
            <div class="input-group">
                <label>Telefone</label>
                <div class="input-wrapper">
                    <i class="fa fa-phone"></i>
                    <input asp-for="Telefone"
                           placeholder="(99) 99999-9999"
                           maxlength="15" />
                </div>
                <span asp-validation-for="Telefone" class="text-danger"></span>
            </div>

            <!-- SENHA -->
            <div class="input-group">
                <label>Senha</label>
                <div class="input-wrapper">
                    <i class="fa fa-lock"></i>
                    <input asp-for="Senha" type="password" />
                </div>
                <span asp-validation-for="Senha" class="text-danger"></span>
            </div>

            <!-- CONFIRMAR SENHA -->
            <div class="input-group">
                <label>Confirmar Senha</label>
                <div class="input-wrapper">
                    <i class="fa fa-lock"></i>
                    <input asp-for="ConfirmarSenha" type="password" />
                </div>
                <span asp-validation-for="ConfirmarSenha" class="text-danger"></span>
            </div>

            <!-- PERFIL -->
            <div class="input-group">
                <label>Perfil</label>
                <div class="input-wrapper">
                    <i class="fa fa-users"></i>
                    <select asp-for="Perfil">
                        <option value="Usuario">Usuario</option>
                        <option value="Administrador">Administrador</option>
                    </select>
                </div>
                <span asp-validation-for="Perfil" class="text-danger"></span>
            </div>

            <button type="submit" class="btn-cadastro">
                Cadastrar
            </button>

            <a asp-controller="Login" asp-action="Index" class="btn-voltar">
                <i class="fa fa-arrow-left"></i>
                Voltar para Login
            </a>

        </form>

    </div>

    <!-- VALIDAÇÃO FRONT-END -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.12/jquery.validate.unobtrusive.min.js"></script>

</body>
</html>