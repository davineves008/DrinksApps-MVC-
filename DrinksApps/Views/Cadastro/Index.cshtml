@model DrinksApps.Models.Usuario

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DrinksApps - Cadastro</title>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

    <style>
        /* SEU CSS MANTIDO */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI';
        }

        body {
            background: linear-gradient(135deg, #1f1c2c 0%, #928dab 100%);
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .cadastro-container {
            background-color: #fff;
            padding: 2.5rem;
            border-radius: 16px;
            width: 100%;
            max-width: 420px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.2);
        }

        .input-group {
            margin-bottom: 1rem;
        }

        label {
            font-size: 0.85rem;
            font-weight: 600;
            margin-bottom: 5px;
            display: block;
        }

        .input-wrapper {
            position: relative;
        }

            .input-wrapper i {
                position: absolute;
                left: 12px;
                top: 50%;
                transform: translateY(-50%);
                color: #aaa;
            }

            .input-wrapper input,
            .input-wrapper select {
                width: 100%;
                padding: 12px 12px 12px 38px;
                border: 1.5px solid #eaeaea;
                border-radius: 8px;
                background: #f9f9f9;
            }

                .input-wrapper input:focus,
                .input-wrapper select:focus {
                    border-color: #ff4757;
                    background: #fff;
                    outline: none;
                }

        .text-danger {
            font-size: 12px;
            color: #dc3545;
            margin-top: 4px;
        }

        .validation-summary-errors {
            color: #dc3545;
            font-size: 13px;
            margin-bottom: 10px;
        }

        .btn-cadastro {
            width: 100%;
            padding: 14px;
            border: none;
            border-radius: 8px;
            background: linear-gradient(135deg, #ff4757, #ff6b81);
            color: #fff;
            font-weight: bold;
            cursor: pointer;
        }

            .btn-cadastro:hover {
                box-shadow: 0 5px 15px rgba(255,71,87,0.4);
            }
    </style>
</head>

<body>

    <div class="cadastro-container">

        <div class="cadastro-header" style="text-align:center; margin-bottom:20px;">
            <i class="fa-solid fa-user-plus" style="font-size:40px; color:#ff4757;"></i>
            <h2>Criar Conta</h2>
        </div>

        <form asp-action="Index" method="post">
            @Html.AntiForgeryToken()

            <!-- RESUMO DE ERROS -->
            <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

            <!-- NOME -->
            <div class="input-group">
                <label>Nome</label>
                <div class="input-wrapper">
                    <i class="fa fa-user"></i>
                    <input asp-for="Nome" />
                </div>
                <span asp-validation-for="Nome" class="text-danger"></span>
            </div>

            <!-- EMAIL -->
            <div class="input-group">
                <label>Email</label>
                <div class="input-wrapper">
                    <i class="fa fa-envelope"></i>
                    <input asp-for="Email" placeholder="Digite seu e-mail" />
                </div>
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <!-- TELEFONE -->
            <div class="input-group">
                <label>Telefone</label>
                <div class="input-wrapper">
                    <i class="fa fa-phone"></i>
                    <input asp-for="Telefone"
                           placeholder="(99) 99999-9999"
                           maxlength="15" />
                </div>
                <span asp-validation-for="Telefone" class="text-danger"></span>
            </div>

            <!-- SENHA -->
            <div class="input-group">
                <label>Senha</label>
                <div class="input-wrapper">
                    <i class="fa fa-lock"></i>
                    <input asp-for="Senha" type="password" />
                </div>
                <span asp-validation-for="Senha" class="text-danger"></span>
            </div>

            <!-- CONFIRMAR SENHA -->
            <div class="input-group">
                <label>Confirmar Senha</label>
                <div class="input-wrapper">
                    <i class="fa fa-lock"></i>
                    <input asp-for="ConfirmarSenha" type="password" />
                </div>
                <span asp-validation-for="ConfirmarSenha" class="text-danger"></span>
            </div>

            <!-- PERFIL -->
            <div class="input-group">
                <label>Perfil</label>
                <div class="input-wrapper">
                    <i class="fa fa-users"></i>
                    <select asp-for="Perfil">
                        <option value="Cliente">Cliente</option>
                        <option value="Administrador">Administrador</option>
                    </select>
                </div>
                <span asp-validation-for="Perfil" class="text-danger"></span>
            </div>

            <button type="submit" class="btn-cadastro">
                Cadastrar
            </button>

        </form>

    </div>

    <!-- VALIDAÇÃO FRONT-END -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.12/jquery.validate.unobtrusive.min.js"></script>

</body>
</html>