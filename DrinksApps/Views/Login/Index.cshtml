@* Se a sua View utiliza um Layout padrão, você pode definir como null se quiser que a tela de login use a página inteira *@
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DrinksApps - Login</title>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

    <style>
        /* Configurações Gerais / Reset */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', sans-serif;
        }

        body {
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            background: linear-gradient(135deg,#ff8c00,#ff6b00,#ff9f43);
            background-size: 300% 300%;
            animation: fundo 10s ease infinite;
        }

        @@keyframes fundo {
            0% {
                background-position: 0% 50%;
            }

            50% {
                background-position: 100% 50%;
            }

            100% {
                background-position: 0% 50%;
            }
        }

        /* CARD */

        .login-container {
            width: 100%;
            max-width: 480px;
            padding: 40px;
            background: rgba(255,255,255,.97);
            border-radius: 25px;
            box-shadow: 0 20px 50px rgba(0,0,0,.25);
            animation: entrar .6s ease;
            border-top: 5px solid #ff7a00;
        }



        /* LOGO */
        .logo-area {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 25px;
            margin-bottom: 35px;
        }

        .logo-icon {
            width: 120px;
            height: 120px;
            border-radius: 50%;
            background: linear-gradient(135deg,#ff6b00,#ff9800);
            display: flex;
            justify-content: center;
            align-items: center;
            box-shadow: 0 15px 35px rgba(255,122,0,.35);
            flex-shrink: 0;
        }

        .logo-icons {
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            line-height: 1;
            gap: 8px;
            font-size: 40px;
        }

        .logo-text {
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

            .logo-text h1 {
                margin: 0;
                color: #ff6b00;
                font-size: 54px;
                font-weight: 800;
                line-height: 1;
            }

            .logo-text p {
                margin-top: 10px;
                color: #666;
                font-size: 20px;
            }
        /* HEADER */


        /* INPUTS */


        .input-group {
            margin-bottom: 25px;
        }


            .input-group label {
                font-size: 14px;
                font-weight: 600;
                color: #333;
            }



        .input-wrapper {
            position: relative;
            margin-top: 8px;
        }


        .input-icon {
            position: absolute;
            left: 15px;
            top: 50%;
            transform: translateY(-50%);
            color: #aaa;
        }



        .input-wrapper input {
            width: 100%;
            height: 50px;
            border-radius: 12px;
            border: 1px solid #ddd;
            padding-left: 45px;
            font-size: 15px;
            background: #fafafa;
            transition: .3s;
        }



            .input-wrapper input:focus {
                border-color: #ff7a00;
                background: white;
                box-shadow: 0 0 0 4px rgba(255,122,0,.18);
            }



        /* ESQUECEU */


        .forgot-link {
            color: #ff6b00;
            font-size: 13px;
            text-decoration: none;
        }

        .login-footer a {
            color: #ff6b00;
            font-weight: bold;
            text-decoration: none;
        }



        /* BOTÃO */


        .btn-login {
            width: 100%;
            height: 55px;
            border: none;
            border-radius: 14px;
            background: linear-gradient(135deg,#ff6b00,#ff9800);
            color: white;
            font-size: 17px;
            font-weight: bold;
            cursor: pointer;
            transition: .3s;
        }


            .btn-login:hover {
                transform: translateY(-3px);
                box-shadow: 0 10px 25px rgba(255,122,0,.40);
            }



        /* FOOTER */


        .login-footer {
            text-align: center;
            margin-top: 25px;
        }


            .login-footer a {
                color: #ff4757;
                font-weight: bold;
            }


        /* ANIMAÇÃO */

        @@keyframes entrar {

            from {
                opacity: 0;
                transform: translateY(30px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }

    </style>
</head>
<body>
    

    @if (ViewBag.Erro != null)
    {
        <div style="background-color:#e74c3c;color:white;padding:12px;border-radius:8px;margin-bottom:15px;text-align:center;">
            @ViewBag.Erro
        </div>
    }

    @if (TempData["Sucesso"] != null)
    {
        <div style="background-color:#2ecc71;color:white;padding:12px;border-radius:8px;margin-bottom:15px;text-align:center;">
            @TempData["Sucesso"]
        </div>
    }

    <div class="login-container">
        <div class="logo-area">

            <div class="logo-icon">
                <div class="logo-icons">
                    <span>🍔</span>
                    <span>🥤</span>
                </div>
            </div>

            <div class="logo-text">
                <h1>DrinksApps</h1>
                <p>Pedidos rápidos e práticos</p>
            </div>

        </div>

        <form asp-action="Index" method="post">
            @* O método POST é importante para enviar os dados de login com segurança *@
            <div class="input-group">
                <label for="email">E-mail</label>
                <div class="input-wrapper">
                    <i class="fa-regular fa-envelope input-icon"></i>
                    <input type="email" id="email" name="email" placeholder="seu@email.com" required>
                </div>
            </div>

            <div class="input-group">
                <div class="label-flex">
                    <label for="password">Senha</label>
                    <a asp-controller="Cadastro" asp-action="Index" class="forgot-link">
                        Esqueceu a senha?
                    </a>
                </div>
                <div class="input-wrapper">
                    <i class="fa-solid fa-lock input-icon"></i>
                    <input type="password" id="senha" name="senha" placeholder="Sua senha" required>
                </div>
            </div>

            <button type="submit" class="btn-login">Entrar</button>

            <div class="login-footer">
                <a asp-controller="Cadastro" asp-action="Index">
                    Criar conta
                </a>
            </div>
        </form>
    </div>

</body>
</html>