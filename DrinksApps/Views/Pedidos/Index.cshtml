@model IEnumerable<DrinksApps.Models.Pedido>

@{
    ViewData["Title"] = "Pedidos";
}

<style>
    .page-card {
        background: #fff;
        border-radius: 16px;
        box-shadow: 0 10px 25px rgba(0,0,0,.08);
        overflow: hidden;
        border: 1px solid #ffe2c4;
    }

    .page-header {
        padding: 20px 25px;
        background: linear-gradient(135deg,#ff7a00,#ff9900);
        color: white;
    }

        .page-header h2 {
            margin: 0;
            font-weight: 700;
        }

    .page-body {
        padding: 25px;
    }

    .card-pedido {
        border: none;
        border-radius: 16px;
        box-shadow: 0 8px 20px rgba(0,0,0,.08);
        transition: .3s;
    }

        .card-pedido:hover {
            transform: translateY(-5px);
            box-shadow: 0 12px 28px rgba(255,122,0,.25);
        }

    .valor {
        color: #ff7a00;
        font-weight: bold;
        font-size: 20px;
    }

    .badge-status {
        padding: 8px 14px;
        border-radius: 20px;
        font-size: 13px;
        font-weight: 600;
    }

    .status-pendente {
        background: #fff4e6;
        color: #ff7a00;
    }

    .status-preparo {
        background: #ffe8cc;
        color: #e86f00;
    }

    .status-entrega {
        background: #ffd8a8;
        color: #cc5c00;
    }

    .status-entregue {
        background: #ffeacc;
        color: #b35400;
    }

    .btn-new {
        background: linear-gradient(135deg,#ff7a00,#ff9900);
        color: white;
        border: none;
        font-weight: 600;
        border-radius: 10px;
        padding: 8px 16px;
        transition: .3s;
    }

        .btn-new:hover {
            background: linear-gradient(135deg,#e86f00,#ff7a00);
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(255,122,0,.35);
        }
</style>

<div class="container py-5">

    <div class="page-card">

        <div class="page-header d-flex justify-content-between align-items-center">

            <h2>📦 Pedidos</h2>

            <form asp-action="ApagarHistorico" method="post"
                  onsubmit="return confirm('Deseja apagar todo o seu histórico de pedidos? Esta ação não poderá ser desfeita.');">

                @Html.AntiForgeryToken()

                <button type="submit" class="btn btn-danger">
                    <i class="fas fa-trash"></i> Apagar Histórico
                </button>
            </form>

        </div>

        <div class="page-body">

            <div class="row g-4">

                @foreach (var item in Model)
                {
                    <div class="col-lg-4 col-md-6">

                        <div class="card card-pedido h-100">

                            <div class="card-body">

                                <h5 class="fw-bold">
                                    Pedido #@item.Id
                                </h5>

                                <hr />

                                <p>
                                    <strong>📅 Data:</strong><br />
                                    @item.DataPedido.ToString("dd/MM/yyyy HH:mm")
                                </p>

                                <p>
                                    <strong>👤 Cliente:</strong><br />
                                    @item.Usuario?.Nome
                                </p>

                                <p>
                                    <strong>💰 Total:</strong><br />

                                    <span class="valor">
                                        @item.ValorTotal.ToString("C")
                                    </span>
                                </p>

                                <p>

                                    <strong>Status:</strong><br />

                                    @if (item.Status == "Pendente")
                                    {
                                        <span class="badge-status status-pendente">
                                            🟡 Pendente
                                        </span>
                                    }
                                    else if (item.Status == "Em preparo")
                                    {
                                        <span class="badge-status status-preparo">
                                            👨‍🍳 Em preparo
                                        </span>
                                    }
                                    else if (item.Status == "Saiu para entrega")
                                    {
                                        <span class="badge-status status-entrega">
                                            🚚 Saiu para entrega
                                        </span>
                                    }
                                    else if (item.Status == "Confirmado")
                                    {
                                        <span class="badge-status status-preparo">
                                            ✅ Confirmado
                                        </span>
                                    }
                                    else if (item.Status == "Cancelado")
                                    {
                                        <span class="badge-status bg-danger text-white">
                                            ❌ Cancelado
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">
                                            @item.Status
                                        </span>
                                    }

                                </p>
                            </div>
                            <div class="card-footer bg-white border-0 d-flex justify-content-between">

                                <a asp-action="Details"
                                   asp-route-id="@item.Id"
                                   class="btn btn-outline-primary btn-sm">
                                    Detalhes
                                </a>


                                <div>

                                    @if (item.Status == "Pendente")
                                    {
                                        <form asp-action="Cancelar"
                                              asp-route-id="@item.Id"
                                              method="post"
                                              class="d-inline">

                                            @Html.AntiForgeryToken()

                                            <button type="submit"
                                                    class="btn btn-danger btn-sm"
                                                    onclick="return confirm('Deseja cancelar este pedido?')">

                                                ❌ Cancelar

                                            </button>

                                        </form>
                                    }
                                </div>


                            </div>

                            </div>

                        </div>

                    
                }

            </div>

        </div>

    </div>

</div>