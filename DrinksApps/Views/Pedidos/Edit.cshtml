@model DrinksApps.Models.Pedido

@{
    ViewData["Title"] = "Editar Pedido";
}

<div class="container mt-4">

    <div class="row justify-content-center">
        <div class="col-md-6">

            <div class="card shadow-lg">
                <div class="card-header bg-primary text-white text-center">
                    <h4>Editar Pedido</h4>
                </div>

                <div class="card-body">

                    <form asp-action="Edit">

                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <input type="hidden" asp-for="Id" />

                        <div class="mb-3">
                            <label asp-for="DataPedido" class="form-label"></label>
                            <input asp-for="DataPedido" class="form-control" type="datetime-local" />
                            <span asp-validation-for="DataPedido" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ValorTotal" class="form-label"></label>
                            <input asp-for="ValorTotal" class="form-control" />
                            <span asp-validation-for="ValorTotal" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Status" class="form-label"></label>
                            <select asp-for="Status" class="form-select">
                                <option value="Pendente">Pendente</option>
                                <option value="Preparando">Preparando</option>
                                <option value="Finalizado">Finalizado</option>
                                <option value="Cancelado">Cancelado</option>
                            </select>
                            <span asp-validation-for="Status" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="UsuarioId" class="form-label"></label>
                            <input asp-for="UsuarioId" class="form-control" readonly />
                            <span asp-validation-for="UsuarioId" class="text-danger"></span>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-success">
                                Salvar alteraçőes
                            </button>

                            <a asp-action="Index" class="btn btn-secondary">
                                Voltar
                            </a>
                        </div>

                    </form>

                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}