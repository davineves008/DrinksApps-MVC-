@model DrinksApps.Models.Pedido

@{
    ViewData["Title"] = $"Editar Pedido #{Model?.Id ?? 0}";
}
<style>

    body {
        background: #f5f5f5;
    }

    .card-pedido {
        border: none;
        border-radius: 18px;
        box-shadow: 0 10px 25px rgba(0,0,0,.08);
    }

    .card-header {
        border-radius: 18px 18px 0 0 !important;
    }

    .titulo {
        font-size: 28px;
        font-weight: bold;
    }

    .form-label {
        font-weight: 600;
        color: #555;
    }

    .btn {
        border-radius: 10px;
    }

    .info-box {
        background: #f8f9fa;
        border-radius: 10px;
        padding: 15px;
        margin-bottom: 20px;
    }

</style>

<div class="container py-5">

    <div class="row justify-content-center">

        <div class="col-lg-7">

            <div class="card card-pedido">

                <div class="card-header bg-primary text-white text-center">
                    <h3 class="titulo mb-0">
                        ✏️ Editar Pedido #@(Model?.Id ?? 0)
                    </h3>

                </div>

                <div class="card-body p-4">


                    <form asp-controller="Pedidos" asp-action="Edit" method="post">

                        @Html.AntiForgeryToken()

                        <div asp-validation-summary="ModelOnly"
                             class="alert alert-danger">
                        </div>

                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="UsuarioId" />

                        <div class="info-box">

                            <div class="row">

                                <div class="col-md-6 mb-3">

                                    <label asp-for="DataPedido"
                                           class="form-label"></label>

                                    <input asp-for="DataPedido"
                                           class="form-control"
                                           readonly />

                                </div>

                                @if (Model.Status == "Pendente")
                                {
                                    <input asp-for="ValorTotal"
                                           class="form-control"
                                           type="number"
                                           step="0.01" />
                                }
                                else
                                {
                                    <input asp-for="ValorTotal"
                                           class="form-control"
                                           readonly />
                                }
                            </div>

                            <div class="mb-3">

                                <label asp-for="UsuarioId"
                                       class="form-label">
                                    Cliente
                                </label>
                                <input type="text"
                                       class="form-control"
                                       readonly
                                       value="@Model.Usuario.Nome" />

                            </div>

                        </div>

                        <div class="mb-4">

                            <label class="form-label">
                                Status do Pedido
                            </label>

                            <input class="form-control"
                                   value="@Model.Status"
                                   readonly />

                        </div>
                    </form>

                </div>

            </div>

        </div>

    </div>

</div>

@section Scripts
{
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}