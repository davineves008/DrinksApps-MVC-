@model DrinksApps.Models.Pedido

@{
    ViewData["Title"] = "Pagamento";
}

<style>

    body {
        background: linear-gradient(135deg,#fff8f0,#ffe8cc);
    }

    .pagamento-card {
        border: none;
        border-radius: 22px;
        overflow: hidden;
        box-shadow: 0 15px 35px rgba(0,0,0,.12);
    }

    .pagamento-header {
        background: linear-gradient(135deg,#ff6b00,#ff9800);
        color: white;
        padding: 20px;
    }

    .total-box {
        background: #fff8f0;
        border-radius: 18px;
        padding: 20px;
        border-left: 6px solid #ff7a00;
    }

    .valor-total {
        font-size: 42px;
        font-weight: bold;
        color: #198754;
    }

    .pix-box {
        background: white;
        border-radius: 18px;
        padding: 25px;
        box-shadow: 0 8px 20px rgba(0,0,0,.08);
    }

    .qr-code {
        border-radius: 15px;
        padding: 10px;
        box-shadow: 0 8px 20px rgba(0,0,0,.15);
    }

    .btn-finalizar {
        background: linear-gradient(135deg,#198754,#20c997);
        border: none;
        border-radius: 14px;
        padding: 15px;
        font-size: 20px;
        font-weight: bold;
        transition: .3s;
    }

        .btn-finalizar:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 25px rgba(25,135,84,.35);
        }

    .forma-pagamento {
        font-size: 18px;
        font-weight: bold;
    }

</style>


<div class="container py-5">

    <div class="row justify-content-center">

        <div class="col-lg-7">

            <div class="card pagamento-card">

                <div class="pagamento-header text-center">

                    <h3 class="mb-0">
                        💳 Pagamento do Pedido #@Model.Id
                    </h3>

                </div>


                <div class="card-body p-4 text-center">


                    <div class="total-box mb-4">

                        <h5>
                            Total do Pedido
                        </h5>

                        <div class="valor-total">
                            @Model.ValorTotal.ToString("C")
                        </div>

                    </div>



                    <div class="forma-pagamento mb-4">

                        Forma de pagamento:
                        <span class="text-primary">
                            @Model.FormaPagamento
                        </span>

                    </div>


                    <hr />


                    @if (Model.FormaPagamento == "Pix")
                    {

                        <div class="pix-box">

                            <h4 class="mb-3">
                                📱 Escaneie o QR Code Pix
                            </h4>


                            <img src="~/images/produtos/Qrcode4.jpeg"
                                 class="qr-code img-fluid"
                                 width="250"
                                 alt="QR Code Pix" />


                            <div class="mt-4">

                                <strong>
                                    PIX Copia e Cola
                                </strong>


                                <div class="alert alert-light mt-2">
                                    00020126580014BR.GOV.BCB.PIX...
                                </div>

                            </div>

                        </div>

                    }

                    else if (Model.FormaPagamento == "Crédito")
                    {
                        <div class="alert alert-primary rounded-4">

                            💳 Pagamento será realizado na entrega utilizando cartão de crédito.

                        </div>
                    }


                    else if (Model.FormaPagamento == "Débito")
                    {
                        <div class="alert alert-info rounded-4">

                            💳 Pagamento será realizado na entrega utilizando cartão de débito.

                        </div>
                    }


                    else if (Model.FormaPagamento == "Dinheiro")
                    {
                        <div class="alert alert-warning rounded-4">

                            💵 Tenha o valor em mãos para facilitar o troco.

                        </div>
                    }



                    <form asp-action="FinalizarPagamento" method="post">

                        @Html.AntiForgeryToken()

                        <input type="hidden"
                               name="id"
                               value="@Model.Id" />


                        <button type="submit"
                                class="btn btn-finalizar text-white w-100 mt-4">

                            ✅ Finalizar Pagamento

                        </button>


                    </form>


                </div>

            </div>

        </div>

    </div>

</div>