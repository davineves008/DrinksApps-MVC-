@model DrinksApps.Models.Pedido

@{
    ViewData["Title"] = "Excluir Pedido";
}

<style>
    .page-card {
        max-width: 700px;
        margin: auto;
        background: #fff;
        border-radius: 18px;
        box-shadow: 0 10px 25px rgba(0,0,0,.08);
        overflow: hidden;
    }

    .page-header {
        background: linear-gradient(135deg,#dc3545,#ff6b6b);
        color: white;
        padding: 20px 30px;
    }

        .page-header h2 {
            margin: 0;
            font-weight: 600;
        }

    .page-body {
        padding: 30px;
    }

    .info-item {
        display: flex;
        justify-content: space-between;
        padding: 12px 0;
        border-bottom: 1px solid #eee;
    }

        .info-item:last-child {
            border-bottom: none;
        }

    .info-label {
        font-weight: 600;
        color: #555;
    }

    .valor {
        color: #198754;
        font-weight: bold;
        font-size: 18px;
    }

    .status {
        padding: 6px 14px;
        border-radius: 20px;
        font-size: 14px;
        font-weight: 600;
    }

    .pendente {
        background: #fff3cd;
        color: #664d03;
    }

    .preparo {
        background: #cfe2ff;
        color: #084298;
    }

    .entrega {
        background: #cff4fc;
        color: #055160;
    }

    .entregue {
        background: #d1e7dd;
        color: #0f5132;
    }
</style>

<div class="container py-5">

    <div class="page-card">

        <div class="page-header">
            <h2>🗑️ Excluir Pedido</h2>
        </div>

        <div class="page-body">

            <div class="alert alert-warning">
                <strong>Atenção!</strong><br />
                Tem certeza que deseja excluir este pedido? Esta ação não poderá ser desfeita.
            </div>

            <div class="info-item">
                <span class="info-label">📦 Pedido</span>
                <span>#@Model.Id</span>
            </div>

            <div class="info-item">
                <span class="info-label">📅 Data</span>
                <span>@Model.DataPedido.ToString("dd/MM/yyyy HH:mm")</span>
            </div>

            <div class="info-item">
                <span class="info-label">💰 Valor Total</span>
                <span class="valor">@Model.ValorTotal.ToString("C")</span>
            </div>

            <div class="info-item">
                <span class="info-label">👤 Cliente</span>
                <span>@Model.UsuarioId</span>
            </div>

            <div class="info-item">
                <span class="info-label">📌 Status</span>

                @if (Model.Status == "Pendente")
                {
                    <span class="status pendente">🟡 Pendente</span>
                }
                else if (Model.Status == "Em preparo")
                {
                    <span class="status preparo">👨‍🍳 Em preparo</span>
                }
                else if (Model.Status == "Saiu para entrega")
                {
                    <span class="status entrega">🚚 Saiu para entrega</span>
                }
                else
                {
                    <span class="status entregue">✅ Entregue</span>
                }

            </div>

            <hr />

            <form asp-action="Delete">

                <input type="hidden" asp-for="Id" />

                <div class="d-flex justify-content-between">

                    <a asp-action="Index" class="btn btn-outline-secondary">
                        ← Cancelar
                    </a>

                    <button type="submit" class="btn btn-danger">
                        🗑️ Excluir Pedido
                    </button>

                </div>

            </form>

        </div>

    </div>

</div>