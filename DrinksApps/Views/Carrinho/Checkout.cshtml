@model DrinksApps.Models.CheckoutView

@{
    ViewData["Title"] = "Checkout";
}

<style>

    body {
        background: #f5f5f5;
    }

    .checkout-card {
        border: none;
        border-radius: 20px;
        box-shadow: 0 10px 25px rgba(0,0,0,.08);
    }

    .titulo {
        font-size: 30px;
        font-weight: bold;
    }

    .resumo-item {
        border-bottom: 1px solid #ececec;
        padding: 12px 0;
    }

    .total {
        font-size: 28px;
        font-weight: bold;
        color: #198754;
    }

    .btn-confirmar {
        height: 55px;
        font-size: 20px;
        font-weight: bold;
        border-radius: 12px;
    }

    .form-label {
        font-weight: 600;
    }

</style>

<div class="container mt-4">

    <h2 class="titulo mb-4">
        🛒 Finalizar Pedido
    </h2>

    <form asp-action="ConfirmarPedido" method="post">

        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

        <div class="row">

            <!-- COLUNA ESQUERDA -->
            <div class="col-lg-7">

                <!-- ENDEREÇO -->
                <div class="card checkout-card mb-4">

                    <div class="card-header bg-danger text-white">
                        <h5 class="mb-0">
                            📍 Endereço de Entrega
                        </h5>
                    </div>

                    <div class="card-body">

                        <div class="row">

                            <div class="col-md-8 mb-3">
                                <label asp-for="Rua" class="form-label"></label>
                                <input asp-for="Rua" class="form-control" />
                                <span asp-validation-for="Rua" class="text-danger"></span>
                            </div>

                            <div class="col-md-4 mb-3">
                                <label asp-for="Numero" class="form-label"></label>
                                <input asp-for="Numero" class="form-control" />
                                <span asp-validation-for="Numero" class="text-danger"></span>
                            </div>

                        </div>

                        <div class="row">

                            <div class="col-md-6 mb-3">
                                <label asp-for="Bairro" class="form-label"></label>
                                <input asp-for="Bairro" class="form-control" />
                                <span asp-validation-for="Bairro" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Cidade" class="form-label"></label>
                                <input asp-for="Cidade" class="form-control" />
                                <span asp-validation-for="Cidade" class="text-danger"></span>
                            </div>

                        </div>

                        <div class="mb-3">
                            <label asp-for="CEP" class="form-label"></label>
                            <input asp-for="CEP" class="form-control" />
                            <span asp-validation-for="CEP" class="text-danger"></span>
                        </div>

                    </div>

                </div>

                <!-- PAGAMENTO -->
                <div class="card checkout-card mb-4">

                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">
                            💳 Forma de Pagamento
                        </h5>
                    </div>

                    <div class="card-body">

                        <div class="form-check">
                            <input asp-for="FormaPagamento" class="form-check-input" type="radio" value="Pix">
                            <label class="form-check-label">Pix</label>
                        </div>

                        <div class="form-check">
                            <input asp-for="FormaPagamento" class="form-check-input" type="radio" value="Crédito">
                            <label class="form-check-label">Cartão de Crédito</label>
                        </div>

                        <div class="form-check">
                            <input asp-for="FormaPagamento" class="form-check-input" type="radio" value="Débito">
                            <label class="form-check-label">Cartão de Débito</label>
                        </div>

                        <div class="form-check mb-2">
                            <input asp-for="FormaPagamento" class="form-check-input" type="radio" value="Dinheiro">
                            <label class="form-check-label">Dinheiro</label>
                        </div>

                        <span asp-validation-for="FormaPagamento" class="text-danger"></span>

                    </div>

                </div>

                <!-- OBSERVAÇÕES -->
                <div class="card checkout-card">

                    <div class="card-header bg-secondary text-white">
                        <h5 class="mb-0">
                            📝 Observações
                        </h5>
                    </div>

                    <div class="card-body">

                        <textarea asp-for="Observacoes"
                                  class="form-control"
                                  rows="4"
                                  placeholder="Ex: Sem cebola, entregar na portaria..."></textarea>

                        <span asp-validation-for="Observacoes" class="text-danger"></span>

                    </div>

                </div>

            </div>

            <!-- COLUNA DIREITA -->
            <div class="col-lg-5">

                <div class="card checkout-card">

                    <div class="card-header bg-success text-white">

                        <h5 class="mb-0">
                            📦 Resumo do Pedido
                        </h5>

                    </div>

                    <div class="card-body">

                        @foreach (var item in Model.Itens)
                        {
                            <div class="resumo-item">

                                <div class="d-flex align-items-center">

                                    <img src="@item.ImagemUrl"
                                         width="70"
                                         height="70"
                                         class="rounded me-3"
                                         style="object-fit:cover;" />

                                    <div class="flex-grow-1">

                                        <strong>@item.Nome</strong>

                                        <br />

                                        <small>
                                            Quantidade: @item.Quantidade
                                        </small>

                                    </div>

                                    <strong class="text-success">
                                        @((item.Preco * item.Quantidade).ToString("C"))
                                    </strong>

                                </div>

                            </div>
                        }

                        <hr />

                        <div class="d-flex justify-content-between mb-3">

                            <h4>Total</h4>

                            <div class="total">
                                @Model.Total.ToString("C")
                            </div>

                        </div>

                        <button type="submit"
                                class="btn btn-success btn-confirmar w-100">

                            ✅ Confirmar Pedido

                        </button>

                    </div>

                </div>

            </div>

        </div>

    </form>

</div>

@section Scripts
{
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}